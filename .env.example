# Chase IntelliWealth configuration

# Shared backend
INTELLIWEALTH_API_HOST=0.0.0.0
INTELLIWEALTH_API_PORT=8000
INTELLIWEALTH_BACKEND_URL=http://127.0.0.1:8000
INTELLIWEALTH_REQUEST_TIMEOUT_MS=20000

# OpenAI / Groq
INTELLIWEALTH_OPENAI_API_KEY=your-api-key-here
INTELLIWEALTH_OPENAI_BASE_URL=https://api.groq.com/openai/v1
INTELLIWEALTH_OPENAI_MODEL=openai/gpt-oss-120b

# Portfolio source
INTELLIWEALTH_PORTFOLIO_CACHE_TTL_SECONDS=300
